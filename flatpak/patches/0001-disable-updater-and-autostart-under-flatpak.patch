@@ -241,6 +241,15 @@ impl AutoLauncher {
     ) -> Result<(), anyhow::Error> {
         info!(target: LOG_TARGET_APP_LOGIC, "Initializing auto-launcher");
 
+        // Inside the Flatpak sandbox `current_exe()` resolves to /app/bin which is
+        // not launchable from the host session. Auto-start must instead be wired up
+        // through the XDG autostart desktop entry (handled by the packaging), so the
+        // crate-based launcher is a no-op here.
+        if std::env::var_os("FLATPAK_ID").is_some() {
+            info!(target: LOG_TARGET_APP_LOGIC, "Running under Flatpak; auto-launch is managed by the desktop autostart entry, skipping crate-based launcher.");
+            return Ok(());
+        }
+
         let app_exe = current_exe()?;
         let app_exe = canonicalize(&app_exe)?;
         let app_name = app_exe
